# 단이브 환경변수 — 실제 값은 .env.local 에 작성하고 커밋하지 않음.
# 키가 비어있으면 자동으로 MSW mock 데이터로 fallback 됩니다.

# ────────────────────────────────────────────────
# Backend API base URL (MSW mock 또는 자체 백엔드)
# ────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:3000


# ────────────────────────────────────────────────
# Supabase — 실제 DB 연결 (회원가입/로그인 등)
# 발급: https://supabase.com → New project → Project Settings → API
#   - URL:       Project URL
#   - anon key:  Project API keys → anon public
# 두 값이 모두 설정되면 자동으로 실제 DB 사용 (MSW auth 핸들러 우회).
# ────────────────────────────────────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=


# ────────────────────────────────────────────────
# 네이버 지도 JavaScript API (PHASE 6)
# 발급: Naver Cloud Platform → AI·NAVER API → Maps → Application Key 발급
# https://console.ncloud.com/naver-service/application
# 발급 후 Web Dynamic Map 서비스 활성화 + Web 서비스 URL 등록(http://localhost:5173 등)
# ────────────────────────────────────────────────
VITE_NAVER_MAP_CLIENT_ID=


# ────────────────────────────────────────────────
# 기상청 단기예보 API (선택)
# 발급: data.go.kr → "기상청_단기예보 ((구)_동네예보) 조회서비스" → 활용신청
# https://www.data.go.kr/data/15084084/openapi.do
# ────────────────────────────────────────────────
VITE_WEATHER_API_KEY=


# ────────────────────────────────────────────────
# 경기버스정보 OpenAPI — 24번 버스 실시간 (선택)
# 발급: gits.go.kr → 시스템소개 → 시스템 자원 신청
# https://www.gits.go.kr/main.do
# ────────────────────────────────────────────────
VITE_GBUS_API_KEY=


# ────────────────────────────────────────────────
# 서울교통공사 실시간 지하철 (선택)
# 발급: data.seoul.go.kr → 데이터셋 → "서울시 지하철 실시간 도착정보" → 인증키 신청
# https://data.seoul.go.kr/dataList/OA-12764/A/1/datasetView.do
# ────────────────────────────────────────────────
VITE_SUBWAY_API_KEY=
